# Optional overrides — you do NOT need this file. Without it, the panel auto-generates a
# persisted session secret (in the data volume) and binds 0.0.0.0. Copy to .env and
# uncomment a line ONLY if you want to override that default.

# Pin the session secret (e.g. to share sessions across hosts) instead of the auto one:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# PI_GW_SESSION_SECRET=

# Restrict the bind address (default 0.0.0.0 = all interfaces):
# PI_GW_BIND_HOST=127.0.0.1
